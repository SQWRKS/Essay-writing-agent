# ──────────────────────────────────────────────
# Essay Writing Agent — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── LLM Provider ───────────────────────────────
# Select the active LLM provider: "openai" (default) or "anthropic"
LLM_PROVIDER=openai

# ── OpenAI Settings ────────────────────────────
# OpenAI API key (required when LLM_PROVIDER=openai)
# Leave blank to use template-based fallbacks.
OPENAI_API_KEY=

# OpenAI model to use (e.g. gpt-4o, gpt-4o-mini, gpt-3.5-turbo)
LLM_MODEL=gpt-4o-mini

# ── Anthropic Settings ─────────────────────────
# Anthropic API key (required when LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# Anthropic model to use (e.g. claude-3-5-haiku-latest, claude-3-5-sonnet-latest)
ANTHROPIC_MODEL=claude-3-5-haiku-latest

# ── Shared LLM Settings ────────────────────────
# Sampling temperature (0.0 – 1.0)
LLM_TEMPERATURE=0.7

# Maximum tokens per LLM response
LLM_MAX_TOKENS=4096

# ── Research Sources ───────────────────────────
# Comma-separated list: arxiv, semantic_scholar, web
RESEARCH_SOURCES=arxiv,semantic_scholar,web

# ── Database ───────────────────────────────────
# Async SQLite connection URL
DATABASE_URL=sqlite+aiosqlite:///./essay_agent.db

# ── Server Ports ───────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Frontend API URL ───────────────────────────
# URL the browser uses to reach the backend API.
# Leave empty (default) to use relative paths through the Vite / nginx proxy,
# which avoids CORS issues.  Set to an explicit URL (e.g. http://localhost:8000)
# only when running the frontend without any reverse-proxy in front of it.
VITE_API_URL=

# ── CORS ───────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Logging ────────────────────────────────────
LOG_LEVEL=INFO
