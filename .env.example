# ──────────────────────────────────────────────
# Essay Writing Agent — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ── LLM Configuration ──────────────────────────
# OpenAI API key (required for LLM-powered agents)
# Leave blank to use template-based fallbacks.
OPENAI_API_KEY=

# Model to use (e.g. gpt-4o, gpt-4o-mini, gpt-3.5-turbo)
LLM_MODEL=gpt-4o-mini

# Sampling temperature (0.0 – 1.0)
LLM_TEMPERATURE=0.7

# Maximum tokens per LLM response
LLM_MAX_TOKENS=4096

# ── Research Sources ───────────────────────────
# Comma-separated list: arxiv, semantic_scholar, web
RESEARCH_SOURCES=arxiv,semantic_scholar,web

# ── Database ───────────────────────────────────
# Async SQLite connection URL
DATABASE_URL=sqlite+aiosqlite:///./essay_agent.db

# ── Server Ports ───────────────────────────────
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── CORS ───────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── Logging ────────────────────────────────────
LOG_LEVEL=INFO
